# Neon database connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Neon Auth URL. In Next.js this must be NEXT_PUBLIC_ because auth runs in the browser.
NEXT_PUBLIC_NEON_AUTH_URL=https://YOUR-ENDPOINT.neonauth.REGION.aws.neon.tech/neondb/auth

# Stripe is currently mocked in code. Add real Stripe keys later when live payments are re-enabled.
